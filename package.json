{
  "name": "demo_crud_rest_api",
  "version": "1.0.0",
  "description": "Task Management REST API with Node.js, Express, and SQLite",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/server.js",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "seed": "node src/seeds/seed.js",
    "db:reset": "knex migrate:rollback && knex migrate:latest && node src/seeds/seed.js"
  },
  "keywords": [
    "rest-api",
    "crud",
    "express",
    "sqlite",
    "knex"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.2.9",
    "sqlite3": "^6.0.1"
  }
}
